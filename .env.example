# Modelo de variáveis de ambiente.
# Copie este arquivo para ".env" e preencha com os valores reais.
# O arquivo ".env" NÃO deve ser versionado (já está no .gitignore).

# Chave secreta do Django (gere uma nova para produção).
SECRET_KEY=coloque-uma-chave-secreta-aqui

# Use False em produção.
DEBUG=True

# Hosts permitidos, separados por vírgula. Ex: meusite.com,127.0.0.1
ALLOWED_HOSTS=

# ----------------------------------------------------------------------------
# Banco de dados Oracle OCI (opcional).
# Se estas variáveis NÃO forem definidas, o projeto usa SQLite automaticamente.
# NUNCA coloque as credenciais reais neste arquivo de exemplo.
# ----------------------------------------------------------------------------
# ORACLE_DSN=(description=...(service_name=...)...)
# ORACLE_USER=ADMIN
# ORACLE_PASSWORD=sua-senha-aqui
